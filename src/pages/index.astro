        if (!("IntersectionObserver" in window)) { els.forEach((el) => el.classList.add("on")); return; }
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("on"); io.unobserve(e.target); } });
        }, { threshold: 0.12, rootMargin: "0px 0px -40px 0px" });
        els.forEach((el) => io.observe(el));
      })();

      // --- Sticky mobile CTA ---
      (function () {
        const sticky = document.getElementById("sticky-cta");
        const hero = document.getElementById("top");
        if (!sticky || !hero) return;
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (!e.isIntersecting) sticky.classList.add("visible"); else sticky.classList.remove("visible"); });
        }, { threshold: 0 });
        io.observe(hero);
      })();

      // --- Cursor spotlight + 3D tilt in hero ---
      (function () {
        const hero = document.getElementById("top");
        const spot = document.getElementById("hero-spotlight");
        const mockup = document.getElementById("hero-mockup");
        if (!hero) return;
        hero.addEventListener("mousemove", (e) => {
          const rect = hero.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          const y = ((e.clientY - rect.top) / rect.height) * 100;
          if (spot) {
            spot.style.setProperty("--mx", x + "%");
            spot.style.setProperty("--my", y + "%");
          }
          if (mockup) {
            const mRect = mockup.getBoundingClientRect();
            const cx = mRect.left + mRect.width / 2;
            const cy = mRect.top + mRect.height / 2;
            const dx = (e.clientX - cx) / mRect.width;
            const dy = (e.clientY - cy) / mRect.height;
            const rotY = Math.max(-6, Math.min(6, dx * 8));
            const rotX = Math.max(-6, Math.min(6, -dy * 6));
            mockup.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
          }
        });
        hero.addEventListener("mouseleave", () => {
          if (mockup) mockup.style.transform = "";
        });
      })();


      // --- Count-up ---
      (function () {
        const items = document.querySelectorAll(".count-up");
        if (!items.length || !("IntersectionObserver" in window)) return;
        function animate(el) {
          const target = parseFloat(el.dataset.count);
          if (isNaN(target)) return;
          const prefix = el.dataset.prefix || "";
          const suffix = el.dataset.suffix || "";
          const duration = 1400;
          const start = performance.now();
          function frame(now) {
            const t = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - t, 3);
            const value = Math.round(target * eased);
            el.textContent = prefix + value + suffix;
            if (t < 1) requestAnimationFrame(frame);
          }
          requestAnimationFrame(frame);
        }
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { animate(e.target); io.unobserve(e.target); } });
        }, { threshold: 0.4 });
        items.forEach((el) => io.observe(el));
      })();

      // --- Horizontal scroll for services ---
      (function () {
        const wrap = document.getElementById("hscroll-wrap");
        const track = document.getElementById("hscroll-track");
        const fill = document.getElementById("hscroll-progress-fill");
        const counter = document.getElementById("hscroll-counter");
        if (!wrap || !track) return;

        let totalDistance = 0;
        let sectionHeight = 0;
        let ticking = false;
        const cardCount = track.children.length;

        function measure() {
          const viewportWidth = window.innerWidth;
          const trackScrollWidth = track.scrollWidth;
          totalDistance = Math.max(0, trackScrollWidth - viewportWidth);
          sectionHeight = wrap.offsetHeight - window.innerHeight;
        }

        function update() {
          const rect = wrap.getBoundingClientRect();
          const scrolled = -rect.top;
          const progress = Math.max(0, Math.min(1, scrolled / sectionHeight));
          const translateX = progress * totalDistance;
          track.style.transform = `translate3d(${-translateX}px, 0, 0)`;
          if (fill) fill.style.width = (progress * 100).toFixed(1) + "%";
          if (counter) {
            const idx = Math.min(cardCount, Math.floor(progress * cardCount) + 1);
            counter.textContent = String(idx).padStart(2, "0") + " / " + String(cardCount).padStart(2, "0");
          }
          ticking = false;
        }

        function onScroll() { if (!ticking) { requestAnimationFrame(update); ticking = true; } }

        measure();
        update();
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", () => { measure(); update(); });
        if (document.fonts && document.fonts.ready) { document.fonts.ready.then(() => { measure(); update(); }); }
      })();

      // --- Booking Modal ---
      (function () {
        const LANDBOT_URL = "https://landbot.pro/v3/H-2753426-MGXKNJGGZIDKJG3U/index.html";
        const modal = document.getElementById("booking-modal");
        const iframe = document.getElementById("booking-iframe");
        const openers = document.querySelectorAll("[data-open-modal]");
        const closers = document.querySelectorAll("[data-close-modal]");
        let iframeLoaded = false;

        function open() {
          if (!iframeLoaded) { iframe.src = LANDBOT_URL; iframeLoaded = true; }
          modal.classList.add("open");
          document.body.style.overflow = "hidden";
        }
        function close() {
          modal.classList.remove("open");
          document.body.style.overflow = "";
        }

        openers.forEach((btn) => btn.addEventListener("click", (e) => { e.preventDefault(); open(); }));
        closers.forEach((btn) => btn.addEventListener("click", close));
        modal.addEventListener("click", (e) => { if (e.target === modal) close(); });
        document.addEventListener("keydown", (e) => { if (e.key === "Escape" && modal.classList.contains("open")) close(); });
      })();

      // --- Team Carousel ---
      (function () {
        var MEMBERS = [
          { name: "Roberto Cortez",   role: "Founder & CMO",        photo: "https://www.spartads.pt/hosted/images/64/d50b6e9c6c4ee09445dad7e919cce7/rob.png",      bio: "Com 12 anos de experiência em marketing digital, Roberto é um dos maiores nomes do setor em Portugal. Mentor da maior comunidade de marketing digital do país, o PAD." },
          { name: "Andreia Rocha",    role: "CEO",                   photo: "https://www.spartads.pt/hosted/images/41/e6e0d4db754cda90911e6a2555743d/andreia.png",   bio: "Especialista em gestão empresarial, Andreia combina mais de 10 anos de experiência com uma visão estratégica clara e determinação." },
          { name: "Ana Leitão",       role: "Head of Operations",    photo: "https://www.spartads.pt/hosted/images/fa/2171166a8d47cb81e00ea9d13ef964/ana.png",       bio: "Engenheira de formação e líder nata, Ana traz mais de uma década de experiência a coordenar grandes equipas no setor industrial." },
          { name: "Patrícia Silva",   role: "PPC Manager",           photo: "https://www.spartads.pt/hosted/images/00/6b574d658d4055ab5cdc32649d4d3b/pat.png",       bio: "Especialista em campanhas de geração de leads e e-commerce, com 4 anos de experiência, Patrícia já geriu estratégias de marketing digital para marcas por toda a Europa." },
          { name: "Bruno Matos",      role: "PPC Manager",           photo: "https://www.spartads.pt/hosted/images/53/394babd8d3467dafa3fe53119a8931/bruno.png",     bio: "Com mais de 500 mil euros em campanhas geridas, Bruno é perito em transformar investimentos publicitários em resultados sólidos." },
          { name: "Eduarda Vale",     role: "PPC Manager",           photo: "https://www.spartads.pt/hosted/images/c7/4db12f358b43e7a8faa0085fcfdd52/edurada.png",   bio: "Natural de Vila Nova de Famalicão, licenciada em economia e apaixonada pelo marketing digital. Focada em estratégias eficazes que geram impacto." },
          { name: "Marcelo Carvalho", role: "PPC Manager",           photo: "https://www.spartads.pt/hosted/images/3f/947e9ad1384d67968f07a946b5b5c0/m.png",        bio: "Natural de Barcelos e apaixonado por inteligência artificial e automações. Focado em processos inovadores e eficientes." },
          { name: "David Enes",       role: "PPC Manager",           photo: "https://www.spartads.pt/hosted/images/20/e31868243f40628420de6ebc8d94fb/david-e.png",   bio: "Com 3 anos de experiência em e-commerce, o David combina pensamento analítico e foco em performance para criar campanhas que geram retornos reais." },
          { name: "Jeferson Pereira", role: "Growth Hacker",         photo: "https://www.spartads.pt/hosted/images/d1/dcdb3278b64fb69f6f3f5335c830ac/jef.png",      bio: "Profissional com 4 anos de experiência, já gerou mais de 20.000 leads e geriu orçamentos superiores a 60.000€. Estratégia digital é a sua praia." },
          { name: "Beatriz Teixeira", role: "Commercial Assistant",  photo: "https://www.spartads.pt/hosted/images/2d/e60f75f8e245b6b1e5e3ab94bb2d6f/bea.png",     bio: "Natural de Fafe, Beatriz é apaixonada por vendas e pela conexão com pessoas. Especialista em servir os clientes e encontrar a melhor solução." },
          { name: "Marcia Aguiar",    role: "Gestora de Projetos",   photo: "https://www.spartads.pt/hosted/images/2c/f8a3405f304d2cb3310015a3a48715/marciar.png",  bio: "Márcia é organizada, próxima e orientada a pessoas. Gosta de criar relações de confiança e garantir que cada cliente se sente acompanhado do início ao fim." },
          { name: "Pedro Pacheco",    role: "Vídeo & Fotografia",    photo: "https://www.spartads.pt/hosted/images/f4/e4ff5f05cc4a37b327e5c7e3f485a2/pedro.png",    bio: "Apaixonado pelo mundo audiovisual, o Pedro especializou-se na captura e edição de vídeo, criando conteúdos visuais que fortalecem a identidade das marcas." },
          { name: "David Ferreira",   role: "Web Designer",          photo: "https://www.spartads.pt/hosted/images/bf/cef8d73c034257bd942d5f32b493ea/david.png",    bio: "De que seria um anúncio sem design? O David desenvolve sites e criativos publicitários que chamam à atenção e geram conversões, há mais de 2 anos." },
          { name: "Pedro Pires",      role: "Web Designer",          photo: "https://www.spartads.pt/hosted/images/1a/caa66f055448a3bd3029db7c524b3c/pires.png",    bio: "Especialista em design com mais de 6 anos de experiência, o Pedro torna as ideias em experiências visuais memoráveis que geram resultados." }
        ];

        var GAP = 20;
        var DRAG_MIN = 55;
        var AUTO_MS  = 5500;

        var viewport = document.getElementById("teamViewport");
        var track    = document.getElementById("teamTrack");
        var dotsEl   = document.getElementById("teamDots");
        var prevBtn  = document.getElementById("teamPrev");
        var nextBtn  = document.getElementById("teamNext");
        if (!track || !viewport) return;

        var N      = MEMBERS.length;
        var active = 0;
        var baseX  = 0;

        // Drag state
        var pDown    = false;
        var pStartX  = 0;
        var pDelta   = 0;
        var didDrag  = false;

        // Auto timer
        var autoTimer = null;

        // Build cards
        MEMBERS.forEach(function (m, i) {
          var el = document.createElement("div");
          el.className = "tcard";
          el.innerHTML =
            '<img class="tcard-img" src="' + m.photo + '" alt="' + m.name + '" loading="lazy">' +
            '<div class="tcard-overlay">' +
              '<div class="tcard-name">' + m.name + '</div>' +
              '<div class="tcard-role">' + m.role + '</div>' +
              '<div class="tcard-bio">'  + m.bio  + '</div>' +
            '</div>';
          el.addEventListener("click", function () {
            if (!didDrag && i !== active) goTo(i);
          });
          track.appendChild(el);
        });

        // Build dots
        MEMBERS.forEach(function (m, i) {
          var d = document.createElement("button");
          d.className = "tcarousel-dot";
          d.setAttribute("aria-label", "Ir para " + m.name);
          d.addEventListener("click", function () { goTo(i); });
          dotsEl.appendChild(d);
        });

        function cardWidth() {
          var c = track.children[0];
          return c ? c.offsetWidth : 280;
        }

        function computeBaseX() {
          var cw   = cardWidth();
          var slot = cw + GAP;
          var vpW  = viewport.offsetWidth;
          return vpW / 2 - active * slot - cw / 2;
        }

        function setTranslate(tx, animate) {
          track.style.transition = animate
            ? "transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94)"
            : "none";
          track.style.transform = "translateX(" + tx + "px)";
        }

        function updateClasses() {
          var cards = track.children;
          for (var i = 0; i < cards.length; i++) {
            var diff = Math.min(Math.abs(i - active), N - Math.abs(i - active));
            cards[i].classList.remove("is-active","is-adj1","is-adj2","is-hidden");
            if      (diff === 0) cards[i].classList.add("is-active");
            else if (diff === 1) cards[i].classList.add("is-adj1");
            else if (diff === 2) cards[i].classList.add("is-adj2");
            else                 cards[i].classList.add("is-hidden");
          }
          var dots = dotsEl.children;
          for (var j = 0; j < dots.length; j++) {
            dots[j].classList.toggle("is-active", j === active);
          }
        }

        function render(animate) {
          baseX = computeBaseX();
          setTranslate(baseX, animate !== false);
          updateClasses();
        }

        function goTo(idx) {
          active = ((idx % N) + N) % N;
          render(true);
          resetAuto();
        }

        // Pointer events — handles mouse + touch in one place
        viewport.addEventListener("pointerdown", function (e) {
          if (e.target.closest("button")) return;
          pDown   = true;
          didDrag = false;
          pStartX = e.clientX;
          pDelta  = 0;
          track.style.transition = "none";
          viewport.classList.add("is-dragging");
          viewport.setPointerCapture(e.pointerId);
        });

        viewport.addEventListener("pointermove", function (e) {
          if (!pDown) return;
          pDelta = e.clientX - pStartX;
          if (Math.abs(pDelta) > 6) didDrag = true;
          track.style.transform = "translateX(" + (baseX + pDelta) + "px)";
        });

        viewport.addEventListener("pointerup", function () {
          if (!pDown) return;
          pDown = false;
          viewport.classList.remove("is-dragging");
          if (Math.abs(pDelta) >= DRAG_MIN) {
            goTo(active + (pDelta < 0 ? 1 : -1));
          } else {
            render(true);
          }
          setTimeout(function () { didDrag = false; }, 0);
        });

        viewport.addEventListener("pointercancel", function () {
          pDown = false;
          viewport.classList.remove("is-dragging");
          render(true);
          didDrag = false;
        });

        viewport.addEventListener("dragstart", function (e) { e.preventDefault(); });

        // Nav buttons
        if (prevBtn) prevBtn.addEventListener("click", function () { goTo(active - 1); });
        if (nextBtn) nextBtn.addEventListener("click", function () { goTo(active + 1); });

        // Auto-rotate
        function startAuto() { autoTimer = setInterval(function () { goTo(active + 1); }, AUTO_MS); }
        function stopAuto()  { clearInterval(autoTimer); }
        function resetAuto() { stopAuto(); startAuto(); }

        viewport.addEventListener("mouseenter", stopAuto);
        viewport.addEventListener("mouseleave", startAuto);

        // Resize
        window.addEventListener("resize", function () { render(false); });

        // Init — sem animação
        render(false);
        startAuto();
      })();
    </script>
  </body>
</html>
